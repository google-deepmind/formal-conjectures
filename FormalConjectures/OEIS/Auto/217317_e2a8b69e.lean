import FormalConjectures.Util.ProblemImports

open Nat Real

/--
A217317: Number of primes between $n^2$ and $n^2 + \log_2(n)^2$ (inclusive).
The sequence is generated by the formula $\pi(\lfloor n^2 + \log_2(n)^2 \rfloor) - \pi(n^2)$,
which counts primes strictly greater than $n^2$.
-/
noncomputable def A217317 (n : ℕ) : ℕ :=
  if n = 0 then 0
  else
    -- Calculate the upper bound $\lfloor n^2 + \log_2(n)^2 \rfloor$
    let upper_bound_real : ℝ := (n : ℝ)^2 + (Real.logb 2 n)^2
    let upper_bound_nat : ℕ := Int.toNat (Int.floor upper_bound_real)

    -- The formula $\pi(b) - \pi(a)$ counts primes $p$ such that $a < p \le b$.
    -- $n^2$ is $\pi(n^2)$ which counts primes $\le n^2$.
    Nat.primeCounting upper_bound_nat - Nat.primeCounting (n^2)

/--
Conjecture: $A217317(n) > 0$ for $n > 4765516$.
-/
theorem oeis_217317_conjecture_0 : ∀ (n : ℕ), n > 4765516 → A217317 n > 0 :=
  by sorry
