module

public import Mathlib.Algebra.FreeAlgebra
public import Mathlib.Algebra.RingQuot

@[expose] public section

/-!
# The Weyl algebra

For a commutative ring `R` and an index type `Ïƒ`, we define the Weyl algebra
`WeylAlgebra R Ïƒ` as the quotient of the free `R`-algebra on `Ïƒ âŠ• Ïƒ` by the two-sided
ideal generated by the canonical commutation relations: writing `x i` for the generator
indexed by `Sum.inl i` and `y i` for the one indexed by `Sum.inr i`,

* `x i * x j = x j * x i`;
* `y i * y j = y j * y i`;
* `x i * y j = y j * x i` for `i â‰  j`;
* `x i * y i = y i * x i + 1`.

For `Ïƒ = Fin n` this is the `n`-th Weyl algebra $A_n(R)$: the associative `R`-algebra
with `2n` generators $Y_1, \dots, Y_{2n}$ subject to $[Y_i, Y_{i+n}] = 1$ and all other
pairs of generators commuting (`Sum.inl i` is $Y_i$, `Sum.inr i` is $Y_{i+n}$). Over a
field of characteristic zero it is the algebra of polynomial-coefficient differential
operators in `n` variables.

Historical remark: Adjamagbo and van den Essen
([AvdE07](https://arxiv.org/abs/math/0608009), Epilogue) argue that the algebra was
introduced by Dirac in 1926 and should be called the "Dirac quantum algebra"; we keep the
name in universal use.
-/

namespace WeylAlgebra

variable (R : Type*) [CommRing R] (Ïƒ : Type*)

/-- The canonical commutation relations presenting the Weyl algebra as a quotient of the
free algebra on `Ïƒ âŠ• Ïƒ`: the `Sum.inl` generators pairwise commute, the `Sum.inr`
generators pairwise commute, and the commutator of the `i`-th `Sum.inl` generator with the
`j`-th `Sum.inr` generator is `Î´ i j`. -/
inductive Rel : FreeAlgebra R (Ïƒ âŠ• Ïƒ) â†’ FreeAlgebra R (Ïƒ âŠ• Ïƒ) â†’ Prop
  | inl_mul_comm (i j : Ïƒ) :
      Rel (FreeAlgebra.Î¹ R (Sum.inl i) * FreeAlgebra.Î¹ R (Sum.inl j))
        (FreeAlgebra.Î¹ R (Sum.inl j) * FreeAlgebra.Î¹ R (Sum.inl i))
  | inr_mul_comm (i j : Ïƒ) :
      Rel (FreeAlgebra.Î¹ R (Sum.inr i) * FreeAlgebra.Î¹ R (Sum.inr j))
        (FreeAlgebra.Î¹ R (Sum.inr j) * FreeAlgebra.Î¹ R (Sum.inr i))
  | inl_mul_inr_of_ne {i j : Ïƒ} (h : i â‰  j) :
      Rel (FreeAlgebra.Î¹ R (Sum.inl i) * FreeAlgebra.Î¹ R (Sum.inr j))
        (FreeAlgebra.Î¹ R (Sum.inr j) * FreeAlgebra.Î¹ R (Sum.inl i))
  | inl_mul_inr_self (i : Ïƒ) :
      Rel (FreeAlgebra.Î¹ R (Sum.inl i) * FreeAlgebra.Î¹ R (Sum.inr i))
        (FreeAlgebra.Î¹ R (Sum.inr i) * FreeAlgebra.Î¹ R (Sum.inl i) + 1)

end WeylAlgebra

/-- The Weyl algebra over `R` on the index type `Ïƒ`: the free `R`-algebra on `Ïƒ âŠ• Ïƒ`
modulo the canonical commutation relations `WeylAlgebra.Rel`. For `Ïƒ = Fin n` this is the
`n`-th Weyl algebra $A_n(R)$. -/
def WeylAlgebra (R : Type*) [CommRing R] (Ïƒ : Type*) : Type _ :=
  RingQuot (WeylAlgebra.Rel R Ïƒ)

namespace WeylAlgebra

variable (R : Type*) [CommRing R] (Ïƒ : Type*)

instance : Ring (WeylAlgebra R Ïƒ) :=
  inferInstanceAs (Ring (RingQuot (Rel R Ïƒ)))

instance : Algebra R (WeylAlgebra R Ïƒ) :=
  inferInstanceAs (Algebra R (RingQuot (Rel R Ïƒ)))

instance : Inhabited (WeylAlgebra R Ïƒ) := âŸ¨0âŸ©

variable {Ïƒ}

/-- The canonical generators of the Weyl algebra: `of R (Sum.inl i)` is the `i`-th
"position" generator ($Y_i$) and `of R (Sum.inr i)` the `i`-th "momentum" generator
($Y_{i+n}$). -/
noncomputable def of (v : Ïƒ âŠ• Ïƒ) : WeylAlgebra R Ïƒ :=
  RingQuot.mkAlgHom R (Rel R Ïƒ) (FreeAlgebra.Î¹ R v)

/-- The position generators pairwise commute. -/
theorem of_inl_mul_comm (i j : Ïƒ) :
    of R (Sum.inl i) * of R (Sum.inl j) = of R (Sum.inl j) * of R (Sum.inl i) := by
  simpa only [of, map_mul] using RingQuot.mkAlgHom_rel R (Rel.inl_mul_comm (R := R) (Ïƒ := Ïƒ) i j)

/-- The momentum generators pairwise commute. -/
theorem of_inr_mul_comm (i j : Ïƒ) :
    of R (Sum.inr i) * of R (Sum.inr j) = of R (Sum.inr j) * of R (Sum.inr i) := by
  simpa only [of, map_mul] using RingQuot.mkAlgHom_rel R (Rel.inr_mul_comm (R := R) (Ïƒ := Ïƒ) i j)

/-- Position and momentum generators with distinct indices commute. -/
theorem of_inl_mul_of_inr_of_ne {i j : Ïƒ} (h : i â‰  j) :
    of R (Sum.inl i) * of R (Sum.inr j) = of R (Sum.inr j) * of R (Sum.inl i) := by
  simpa only [of, map_mul] using RingQuot.mkAlgHom_rel R (Rel.inl_mul_inr_of_ne (R := R) (Ïƒ := Ïƒ) h)

/-- The defining commutation relation: `x i * y i = y i * x i + 1`. -/
theorem of_inl_mul_of_inr_self (i : Ïƒ) :
    of R (Sum.inl i) * of R (Sum.inr i) = of R (Sum.inr i) * of R (Sum.inl i) + 1 := by
  simpa only [of, map_mul, map_add, map_one] using
    RingQuot.mkAlgHom_rel R (Rel.inl_mul_inr_self (R := R) (Ïƒ := Ïƒ) i)

/-- The canonical commutation relation in commutator form: `[x i, y i] = 1`. -/
theorem commutator_of_inl_of_inr_self (i : Ïƒ) :
    of R (Sum.inl i) * of R (Sum.inr i) - of R (Sum.inr i) * of R (Sum.inl i) = 1 := by
  rw [of_inl_mul_of_inr_self, add_sub_cancel_left]

end WeylAlgebra
